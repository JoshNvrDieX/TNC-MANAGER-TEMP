{
  "name": "discord-bot-handler",
  "version": "1.1.0",
  "description": "A versatile Discord.js bot handler",
  "type": "module",
  "scripts": {
    "start": "node src/bot.js",
    "format": "prettier --write \"src/**/*.js\""
  },
  "imports": {
    "#commands/*": "./src/commands/*.js",
    "#command": "./src/structures/classes/command.js",
    "#context": "./src/structures/classes/context.js",
    "#config": "./src/config/config.js",
    "#emoji": "./src/config/emoji.js",
    "#dbManager": "./src/database/manager.js",
    "#db/sqlite": "./src/database/sqlite.js",
    "#structures/*": "./src/structures/*.js",
    "#database/*": "./src/database/*.js",
    "#config/*": "./src/config/*.js",
    "#utils": "./src/utils/index.js",
    "#events/*": "./src/events/*.js",
    "#handlers/*": "./src/structures/handlers/*.js",
    "#classes/*": "./src/structures/classes/*.js",
    "#classes/automodEngine": "./src/structures/classes/automodEngine.js",
    "#classes/automodTracker": "./src/structures/classes/automodTracker.js",
    "#classes/antinukeEngine": "./src/structures/classes/antinukeEngine.js",
    "#classes/workerPool": "./src/structures/classes/workerPool.js",
    "#classes/workerTasks": "./src/structures/classes/workerTasks.js",
    "#classes/dbCache": "./src/structures/classes/dbCache.js",
    "#classes/vc247Manager": "./src/structures/classes/vc247Manager.js",
    "#classes/statusManager": "./src/structures/classes/statusManager.js",
    "#classes/interactionRouter": "./src/structures/classes/interactionRouter.js",
    "#db/*": "./src/database/*.js",
    "#dbRepo/*": "./src/database/repositories/*.js",
    "#dbSchema/*": "./src/database/schema/*.js",
    "#dbServices/*": "./src/database/services/*.js",
"#profileCard": "./src/utils/profileCard.js",
    "#src/*": "./src/*.js"
  },
  "keywords": [
    "discord",
    "bot",
    "discord.js",
    "sharding",
    "modular"
  ],
  "author": "Bre4d777",
  "license": "MIT",
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.18.0",
    "better-sqlite3": "^12.9.0",
    "canvas": "^3.2.3",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.5",
    "fs-extra": "^11.3.3",
    "moonlink.js": "^5.2.0",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
